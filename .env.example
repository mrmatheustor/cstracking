PORT=3000
JWT_SECRET=altere_para_um_segredo_longo_e_aleatorio
JWT_EXPIRES_IN=7d

# E-mail que recebe papel admin (cadastro existente ou novo)
ADMIN_EMAIL=mrmatheustor@gmail.com

# URL publica do app (GSI no .cfg dos jogadores). Ex: https://cstracking.seudominio.com
# Se vazio, usa o host da requisicao; localhost vira http://127.0.0.1:PORT
# GSI_PUBLIC_URL=https://cstracking.seudominio.com

# STEAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Chave em https://steamcommunity.com/dev/apikey (domínio = URL pública do app)

# Forca redirect HTTP -> HTTPS em producao (ou quando GSI_PUBLIC_URL usa https)
# FORCE_HTTPS=1

# Pasta do SQLite. Local: omita (usa ./data). Railway volume em /data: DATA_DIR=/data
# DATA_DIR=/data
